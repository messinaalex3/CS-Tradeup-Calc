{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": ".open-next/worker.js",
	"name": "cs-tradeup-calc",
	"compatibility_date": "2026-04-20",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			// Self-reference service binding, the service name must match the worker name
			// see https://opennext.js.org/cloudflare/caching
			"binding": "WORKER_SELF_REFERENCE",
			"service": "cs-tradeup-calc"
		}
	],
	"images": {
		// Enable image optimization
		// see https://opennext.js.org/cloudflare/howtos/image
		"binding": "IMAGES"
	},
	"kv_namespaces": [
		{
			"binding": "PRICE_CACHE",
			"id": "77a8a9f449fd4014bb19e60f7a20c0bb",
			"remote": true
		},
		{
			// Run `wrangler kv namespace create TRADEUP_CACHE` and replace the id below
			// before deploying to production. Leave the preview_id empty for local dev.
			"binding": "TRADEUP_CACHE",
			"id": "REPLACE_WITH_TRADEUP_CACHE_KV_NAMESPACE_ID",
			"remote": true
		}
	],
	"r2_buckets": [
		{
			"bucket_name": "cs-tradeup-prices",
			"binding": "PRICE_SNAPSHOTS",
			"remote": true
		}
	]
}